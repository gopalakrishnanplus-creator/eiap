# EIAP staging SFTP settings.
# Copy values into your shell environment. Do not commit real credentials.

EIAP_SFTP_HOST=
EIAP_SFTP_PORT=22
EIAP_SFTP_USERNAME=
EIAP_SFTP_PASSWORD=

# For WordPress.com-style SFTP, htdocs is normalized to the SFTP home wp-content target.
# If your provider gives a different root, set the directory that contains wp-content.
EIAP_SFTP_REMOTE_DIR=htdocs
